@model TP.Models.CalculatorViewModel

<div class="d-flex justify-content-center align-items-center vh-100">

    <div class="card shadow-sm" style="width: 380px;">

        <div class="card-header text-center">
            <h4 class="mb-0">Calculator</h4>
        </div>

        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="mb-3">
                    @Html.LabelFor(c => c.FirstNumber, new { @class = "form-label" })
                    @Html.TextBoxFor(c => c.FirstNumber, new { @class = "form-control inputBox" })
                    @Html.ValidationMessageFor(c => c.FirstNumber, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    <label class="form-label">Operation</label>

                    @Html.DropDownListFor(c => c.Sign,
                        new[]
                        {
                            new SelectListItem("+", "+"),
                            new SelectListItem("-", "-"),
                            new SelectListItem("*", "*"),
                            new SelectListItem("/", "/")
                        },
                        "Select operation",
                        new { @class = "form-select signBox" })

                    @Html.ValidationMessageFor(c => c.Sign, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(c => c.SecondNumber, new { @class = "form-label" })
                    @Html.TextBoxFor(c => c.SecondNumber, new { @class = "form-control inputBox" })
                    @Html.ValidationMessageFor(c => c.SecondNumber, "", new { @class = "text-danger" })
                </div>

                <div class="d-grid gap-2">

                    <button type="submit" name="action" value="calculate" class="btn btn-success">
                        Calculate
                    </button>

                    <button type="submit" name="action" value="clear" class="btn btn-secondary">
                        Clear
                    </button>
                    @Html.ActionLink(
                            "Show last operation",
                            "History",
                            "Calculator",
                            null,
                            new { @class = "btn btn-primary" })
                </div>

                <div class="mt-3">
                    <label class="form-label">Result</label>
                    <input class="form-control resultBox" value="@Model?.Result" readonly />
                </div>

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-info mt-2">
                        @ViewBag.Message
                    </div>
                }

            }

        </div>
    </div>
</div>

</div>

